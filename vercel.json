{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api",
      "service": "backend"
    },
    {
      "source": "/(.*)",
      "destination": "/",
      "service": "frontend"
    }
  ]
}
