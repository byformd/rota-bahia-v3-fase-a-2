# Banco de dados (SQLite local por padrão — não precisa de configuração)
DATABASE_URL="file:./dev.db"

# Porta do servidor
PORT=4000

# Origem permitida para CORS (URL do frontend)
CORS_ORIGIN="http://localhost:5173"

# JWT
JWT_SECRET="troque-este-valor-por-um-segredo-forte-em-producao"
JWT_EXPIRES_IN="8h"

# Credenciais do admin criado pelo script de seed (ver package.json > prisma:seed)
ADMIN_NAME="Administrador Rota Bahia"
ADMIN_EMAIL="admin@rotabahia.com.br"
ADMIN_PASSWORD="troque-esta-senha"
